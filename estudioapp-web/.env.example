# Copiar este archivo a .env y completar con las credenciales reales.
# .env NO se commitea (ya está en .gitignore).

# Firebase — mismo proyecto que la app Flutter: estudia-pe
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# App Check — reCAPTCHA v3 (reemplaza a Play Integrity en web)
VITE_RECAPTCHA_SITE_KEY=

# IA — mismas claves que .env de la app Flutter
VITE_GROQ_API_KEY=
VITE_GROQ_MODEL=llama-3.3-70b-versatile
VITE_GEMINI_API_KEY=
VITE_GEMINI_MODEL=gemini-2.5-flash
